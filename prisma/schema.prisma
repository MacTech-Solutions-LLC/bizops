// ---------------------------------------------------------------------------
// Member capability profile (self-service onboarding)
//
// AUTHORITY BOUNDARY — read this before adding a field here.
//
// Hub owns *identity*: legal name, email, avatar, org membership, role, auth.
// Those are resolved per-request from the Hub snapshot (`GovConContext`) and
// are deliberately NOT columns on these models. If you find yourself adding
// `email` or `firstName` below, stop: that re-creates the local identity SoT
// that DR-2026-06-10-01 forbids (see AGENTS.md).
//
// BizOps owns *GovCon capability data*: what a person can be proposed for on a
// federal bid — labor category, clearance, skills, certifications, federal past
// performance. Hub has no concept of these, and they are what a Capability
// Statement is actually built from. `hubUserId` is the opaque join key.
//
// RESUME HANDLING — the uploaded resume binary is never persisted. It is parsed
// in memory and discarded; only the fields the member explicitly confirms are
// written here. `resumeSourceFilename` / `resumeParsedAt` are provenance
// metadata about a parse that happened, not a pointer to a stored file. There
// is intentionally no `storageReference` on this model.
// ---------------------------------------------------------------------------

enum GovConProfileStatus {
  draft // member is still filling it in; excluded from org rollups
  in_review // submitted, awaiting manager confirmation
  published // confirmed; eligible for capability statements
}

enum GovConClearanceLevel {
  none
  public_trust
  confidential
  secret
  top_secret
  ts_sci
}

enum GovConProficiency {
  familiar
  proficient
  expert
}

/// Provenance of an extracted row. Drives the review UI: anything not `manual`
/// is shown as unconfirmed until the member accepts it, so an AI guess is never
/// silently presented as fact the member asserted.
enum GovConFieldSource {
  manual // typed by the member
  heuristic // deterministic parse (regex/section match)
  ai // model-extracted
}

model GovConMemberProfile {
  id                String @id @default(cuid())
  hubOrganizationId String
  /// Opaque Hub user id. Join key only — never a local identity record.
  hubUserId         String

  status GovConProfileStatus @default(draft)

  /// Professional title as it should appear on a capability statement.
  headline        String?
  summary         String?
  laborCategory   String? // LCAT, e.g. "Senior Systems Engineer"
  yearsExperience Int?

  clearanceLevel     GovConClearanceLevel @default(none)
  clearanceGrantedOn DateTime?
  investigationType  String? // T5, T3, SSBI, ...

  /// 0-100, recomputed on every write by `scoreCompleteness`. Denormalised so
  /// org-wide rollups don't have to re-derive it per member.
  completeness Int @default(0)

  // --- Resume parse provenance (metadata only; never the binary) ---
  resumeParsedAt       DateTime?
  resumeSourceFilename String?
  resumeParseModel     String? // model id that produced the extraction

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  skills         GovConMemberSkill[]
  certifications GovConMemberCertification[]
  education      GovConMemberEducation[]
  experience     GovConMemberExperience[]

  @@unique([hubOrganizationId, hubUserId])
  @@index([hubOrganizationId])
  @@index([hubOrganizationId, status])
}

model GovConMemberSkill {
  id        String              @id @default(cuid())
  profileId String
  profile   GovConMemberProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  name            String
  category        String?
  proficiency     GovConProficiency @default(proficient)
  yearsExperience Int?
  source          GovConFieldSource @default(manual)
  /// False until the member accepts an extracted row in the review step.
  confirmed       Boolean           @default(false)

  createdAt DateTime @default(now())

  @@unique([profileId, name])
  @@index([profileId])
}

model GovConMemberCertification {
  id        String              @id @default(cuid())
  profileId String
  profile   GovConMemberProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  name       String
  issuer     String?
  identifier String?
  issuedOn   DateTime?
  expiresOn  DateTime?
  source     GovConFieldSource @default(manual)
  confirmed  Boolean           @default(false)

  createdAt DateTime @default(now())

  @@index([profileId])
  @@index([profileId, expiresOn])
}

model GovConMemberEducation {
  id        String              @id @default(cuid())
  profileId String
  profile   GovConMemberProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  institution String
  degree      String?
  field       String?
  completedOn DateTime?
  source      GovConFieldSource @default(manual)
  confirmed   Boolean           @default(false)

  createdAt DateTime @default(now())

  @@index([profileId])
}

model GovConMemberExperience {
  id        String              @id @default(cuid())
  profileId String
  profile   GovConMemberProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  organization String
  role         String?
  startedOn    DateTime?
  endedOn      DateTime? // null = current
  summary      String?

  // --- Federal past-performance signals (what makes this a GovCon profile) ---
  isFederal    Boolean @default(false)
  agency       String?
  contractName String?

  source    GovConFieldSource @default(manual)
  confirmed Boolean           @default(false)

  createdAt DateTime @default(now())

  @@index([profileId])
  @@index([profileId, isFederal])
}
