  proposalId        String?
  proposal          GovConProposal?    @relation(fields: [proposalId], references: [id], onDelete: SetNull)
  type              GovConReviewType   @default(PINK)
  scheduledAt       DateTime?
  scope             String?
  reviewers         String[] // hubUserIds
  instructions      String?
  status            GovConReviewStatus @default(SCHEDULED)
  closedAt          DateTime?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  createdBy         String?
  updatedBy         String?

  findings GovConReviewFinding[]

  @@index([hubOrganizationId])
  @@index([opportunityId])
}

model GovConReviewFinding {
  id                String              @id @default(cuid())
  hubOrganizationId String
  reviewId          String
  review            GovConReview        @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  summary           String
  detail            String?
  severity          GovConSeverity      @default(MEDIUM)
  ownerId           String? // hubUserId
  resolution        String?
  status            GovConFindingStatus @default(OPEN)
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt

  @@index([hubOrganizationId])
  @@index([reviewId])
