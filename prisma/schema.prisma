// ---------------------------------------------------------------------------
// Tasks and collaboration
// ---------------------------------------------------------------------------

model GovConTask {
  id                String             @id @default(cuid())
  hubOrganizationId String
  title             String
  description       String?
  opportunityId     String?
  opportunity       GovConOpportunity? @relation(fields: [opportunityId], references: [id], onDelete: SetNull)
  proposalId        String?
  proposal          GovConProposal?    @relation(fields: [proposalId], references: [id], onDelete: SetNull)
  proposalVolume    String?
  assigneeId        String? // hubUserId
  creatorId         String? // hubUserId
  watchers          String[] // hubUserIds
  priority          GovConPriority     @default(MEDIUM)
  status            GovConTaskStatus   @default(TODO)
  startDate         DateTime?
  dueAt             DateTime?
  completedAt       DateTime?
  checklistJson     Json? // [{ text, done }]
  tags              String[]
  orderIndex        Int                @default(0)
  version           Int                @default(0)
  isDemo            Boolean            @default(false)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  createdBy         String?
  updatedBy         String?

  comments     GovConComment[]
  dependencies GovConTaskDependency[] @relation("TaskDependent")
  dependents   GovConTaskDependency[] @relation("TaskPrerequisite")

  @@index([hubOrganizationId])
  @@index([opportunityId])
  @@index([hubOrganizationId, status])
  @@index([hubOrganizationId, assigneeId])
  @@index([hubOrganizationId, dueAt])
}

model GovConTaskDependency {
  id                String     @id @default(cuid())
  hubOrganizationId String
  taskId            String
  task              GovConTask @relation("TaskDependent", fields: [taskId], references: [id], onDelete: Cascade)
  dependsOnTaskId   String
  dependsOnTask     GovConTask @relation("TaskPrerequisite", fields: [dependsOnTaskId], references: [id], onDelete: Cascade)
  createdAt         DateTime   @default(now())

  @@unique([taskId, dependsOnTaskId])
  @@index([hubOrganizationId])
}

model GovConComment {
  id                String             @id @default(cuid())
  hubOrganizationId String
  authorId          String // hubUserId
  body              String
  // Attach to any entity via optional typed FKs + a generic pair for the rest.
  opportunityId     String?
  opportunity       GovConOpportunity? @relation(fields: [opportunityId], references: [id], onDelete: Cascade)
  taskId            String?
  task              GovConTask?        @relation(fields: [taskId], references: [id], onDelete: Cascade)
  entityType        String? // capture_section, review_finding, proposal_volume, ...
  entityId          String?
  parentCommentId   String?
  parentComment     GovConComment?     @relation("CommentThread", fields: [parentCommentId], references: [id], onDelete: Cascade)
  replies           GovConComment[]    @relation("CommentThread")
  editedAt          DateTime?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  mentions GovConMention[]

  @@index([hubOrganizationId])
  @@index([opportunityId])
  @@index([taskId])
  @@index([entityType, entityId])
}

model GovConMention {
  id                String        @id @default(cuid())
  hubOrganizationId String
  commentId         String
  comment           GovConComment @relation(fields: [commentId], references: [id], onDelete: Cascade)
  mentionedUserId   String // hubUserId
  createdAt         DateTime      @default(now())

  @@index([hubOrganizationId])
  @@index([mentionedUserId])
  @@index([commentId])
}

model GovConNotification {
  id                String                 @id @default(cuid())
  hubOrganizationId String
  recipientId       String // hubUserId
  type              GovConNotificationType
  title             String
  body              String?
  entityType        String?
  entityId          String?
  opportunityId     String?
  link              String?
  readAt            DateTime?
  actorId           String? // hubUserId who triggered it
  createdAt         DateTime               @default(now())

  @@index([hubOrganizationId])
  @@index([hubOrganizationId, recipientId, readAt])
}

