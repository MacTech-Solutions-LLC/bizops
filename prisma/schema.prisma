// MacTech GovCon Ops — Prisma schema.
//
// Tenancy: every domain row carries `hubOrganizationId` (the MacTech Hub tenant
// key resolved from the Clerk session). There is no local User/Org table —
// identity is the Hub's source of truth, so actors/owners/assignees/watchers are
// stored as opaque Hub user id strings. All queries filter on hubOrganizationId;
// there are no cross-tenant reads.
//
// Legacy models (CompanyProfile, TeamMember, Campaign) are retained
// non-destructively; Campaign is superseded by GovConOpportunity.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
// Legacy models (retained; not the core pipeline model — see GOVCON_REBUILD_AUDIT.md)
// ---------------------------------------------------------------------------

model CompanyProfile {
  id                String   @id @default(cuid())
  hubOrganizationId String   @unique
  legalName         String
  dba               String?
  cageCode          String?
  uei               String?
  naicsPrimary      String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model TeamMember {
  id                String   @id @default(cuid())
  hubOrganizationId String
  hubUserId         String
  displayName       String
  email             String?
  title             String?
  role              String   @default("member")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@unique([hubOrganizationId, hubUserId])
  @@index([hubOrganizationId])
}

model Campaign {
  id                String   @id @default(cuid())
  hubOrganizationId String
  name              String
  status            String   @default("draft")
  description       String?
  leadCount         Int      @default(0)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([hubOrganizationId])
  @@index([hubOrganizationId, status])
}

