  agencyId                  String?
  agency                    GovConAgency?      @relation(fields: [agencyId], references: [id], onDelete: SetNull)
  topicNumber               String
  topicTitle                String
  phase                     GovConSbirPhase    @default(PHASE_I)
  preReleaseDate            DateTime?
  openDate                  DateTime?
  questionsDeadline         DateTime?
  closeDate                 DateTime?
  technicalPoc              String?
  contractingPoc            String?
