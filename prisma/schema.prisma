// ---------------------------------------------------------------------------
// Reference: agencies, offices, contacts, vehicles, partners
// ---------------------------------------------------------------------------

model GovConAgency {
  id                String         @id @default(cuid())
  hubOrganizationId String
  name              String
  abbreviation      String?
  tier              String? // e.g. "cabinet", "sub-agency", "command"
  parentAgencyId    String?
  parentAgency      GovConAgency?  @relation("AgencyHierarchy", fields: [parentAgencyId], references: [id], onDelete: SetNull)
  childAgencies     GovConAgency[] @relation("AgencyHierarchy")
  website           String?
  notes             String?
  isDemo            Boolean        @default(false)
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  createdBy         String?
  updatedBy         String?

  offices       GovConOffice[]
  contacts      GovConContact[]
  opportunities GovConOpportunity[]
  sbirTopics    GovConSbirTopic[]

  @@unique([hubOrganizationId, name])
  @@index([hubOrganizationId])
}

model GovConOffice {
  id                String       @id @default(cuid())
  hubOrganizationId String
  agencyId          String
  agency            GovConAgency @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  name              String
  command           String?
  location          String?
  notes             String?
  isDemo            Boolean      @default(false)
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  contacts      GovConContact[]
  opportunities GovConOpportunity[]

  @@index([hubOrganizationId])
  @@index([agencyId])
}

model GovConContact {
  id                   String        @id @default(cuid())
  hubOrganizationId    String
  name                 String
  title                String?
  organizationName     String?
  agencyId             String?
  agency               GovConAgency? @relation(fields: [agencyId], references: [id], onDelete: SetNull)
  officeId             String?
  office               GovConOffice? @relation(fields: [officeId], references: [id], onDelete: SetNull)
  email                String?
  phone                String?
  contactType          String? // government, teaming, industry, internal
  acquisitionRole      String? // CO, COR, PM, technical
  decisionRole         String? // decision-maker, influencer, gatekeeper, user
  influence            String? // high, medium, low
  relationshipStrength String? // strong, moderate, weak, none
  lastInteractionAt    DateTime?
  nextActionAt         DateTime?
  nextAction           String?
  meetingNotes         String?
  sensitivityNotes     String?
  isDemo               Boolean       @default(false)
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt
  createdBy            String?
  updatedBy            String?

  interactions GovConInteraction[]

  @@index([hubOrganizationId])
  @@index([agencyId])
}

model GovConInteraction {
  id                String             @id @default(cuid())
  hubOrganizationId String
  contactId         String
  contact           GovConContact      @relation(fields: [contactId], references: [id], onDelete: Cascade)
  opportunityId     String?
  opportunity       GovConOpportunity? @relation(fields: [opportunityId], references: [id], onDelete: SetNull)
  occurredAt        DateTime
  channel           String? // call, email, meeting, event
  summary           String
  followUp          String?
  isDemo            Boolean            @default(false)
  createdAt         DateTime           @default(now())
  createdBy         String?

  @@index([hubOrganizationId])
  @@index([contactId])
  @@index([opportunityId])
}

model GovConContractVehicle {
  id                String              @id @default(cuid())
  hubOrganizationId String
  name              String
  vehicleType       String? // IDIQ, GWAC, BPA, GSA Schedule, OTA
  agency            String?
  contractNumber    String?
  primeHolder       String?
  subcontractAccess Boolean             @default(false)
  pools             String[]
  naicsCodes        String[]
  startDate         DateTime?
  endDate           DateTime?
  optionPeriods     Int?
  ceiling           Decimal?            @db.Decimal(16, 2)
  orderingStatus    String?
  status            GovConVehicleStatus @default(PURSUING)
  renewalActions    String?
  notes             String?
  isDemo            Boolean             @default(false)
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  createdBy         String?
  updatedBy         String?

  opportunities GovConOpportunity[]

  @@unique([hubOrganizationId, name])
  @@index([hubOrganizationId])
}

model GovConPartner {
  id                  String                       @id @default(cuid())
  hubOrganizationId   String
  legalName           String
  dba                 String?
  uei                 String?
  cageCode            String?
  businessSize        GovConBusinessSize           @default(UNKNOWN)
  socioeconomicStatus String[] // 8(a), SDVOSB, WOSB, HUBZone, ...
  naicsCapabilities   String[]
  contractVehicles    String[]
  facilityClearance   String?
  keyCapabilities     String?
  pastPerformance     String?
  relationshipOwner   String? // hubUserId
  proposedRole        String?
  ndaStatus           GovConPartnerAgreementStatus @default(NONE)
  teamingStatus       GovConPartnerAgreementStatus @default(NONE)
  subcontractStatus   GovConPartnerAgreementStatus @default(NONE)
  risk                String? // low, medium, high
  notes               String?
  isDemo              Boolean                      @default(false)
  archivedAt          DateTime?
  createdAt           DateTime                     @default(now())
  updatedAt           DateTime                     @updatedAt
  createdBy           String?
  updatedBy           String?

  contacts            GovConPartnerContact[]
  opportunityPartners GovConOpportunityPartner[]
  documents           GovConDocument[]

  @@index([hubOrganizationId])
}

model GovConPartnerContact {
  id                String        @id @default(cuid())
  hubOrganizationId String
  partnerId         String
  partner           GovConPartner @relation(fields: [partnerId], references: [id], onDelete: Cascade)
  name              String
  title             String?
  email             String?
  phone             String?
  isPrimary         Boolean       @default(false)
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  @@index([hubOrganizationId])
  @@index([partnerId])
}

// ---------------------------------------------------------------------------
// Core: opportunities and their lifecycle
// ---------------------------------------------------------------------------

model GovConOpportunity {
  id                String @id @default(cuid())
  hubOrganizationId String

  // Identity
  internalName       String
  solicitationTitle  String?
  solicitationNumber String?
  noticeId           String?
  type               GovConOpportunityType @default(RFP)
  sourceSystem       String? // SAM.gov, GSA eBuy, DSIP, grants.gov
  sourceUrl          String?

  // Customer
  agencyId           String?
  agency             GovConAgency?          @relation(fields: [agencyId], references: [id], onDelete: SetNull)
  subAgency          String?
  officeId           String?
  office             GovConOffice?          @relation(fields: [officeId], references: [id], onDelete: SetNull)
  command            String?
  contractingOffice  String?
  placeOfPerformance String?
  setAside           String?
  naics              String?
  psc                String?
  vehicleId          String?
  vehicle            GovConContractVehicle? @relation(fields: [vehicleId], references: [id], onDelete: SetNull)
  contractType       String? // FFP, T&M, CPFF, ...
  competitionType    GovConCompetitionType  @default(UNKNOWN)

  // Commercial
  estimatedValue            Decimal? @db.Decimal(16, 2)
  minValue                  Decimal? @db.Decimal(16, 2)
  maxValue                  Decimal? @db.Decimal(16, 2)
  ceiling                   Decimal? @db.Decimal(16, 2)
  fundedValue               Decimal? @db.Decimal(16, 2)
  periodOfPerformanceMonths Int?
  basePeriodMonths          Int?
  optionPeriods             Int?

  // Dates
  postedDate            DateTime?
  responseDeadline      DateTime?
  questionsDeadline     DateTime?
  siteVisitDate         DateTime?
  industryDayDate       DateTime?
  draftSolicitationDate DateTime?
  finalSolicitationDate DateTime?
  proposalDeadline      DateTime?
  expectedAwardDate     DateTime?
  actualAwardDate       DateTime?
  debriefDate           DateTime?

  // Pursuit
  stage                  GovConStage    @default(IDENTIFIED)
  health                 GovConHealth   @default(UNKNOWN)
  priority               GovConPriority @default(MEDIUM)
  strategicFit           Int? // 0-100
  pWin                   Int? // probability of win 0-100
  pGo                    Int? // probability of go 0-100
  teamRole               GovConTeamRole @default(UNDECIDED)
  incumbent              String?
  competitors            String[]
  customerPainPoints     String?
  customerHotButtons     String?
  discriminators         String?
  winThemes              String?
  ghostThemes            String?
  blackHatNotes          String?
  solutionHypothesis     String?
  pricingHypothesis      String?
  keyPersonnelNeeds      String?
  clearanceNeeds         String?
  facilityNeeds          String?
  complianceRequirements String?
  bidDecisionSummary     String?
  bidRationale           String?
  noBidRationale         String?

  // Ownership (Hub user ids)
  captureOwnerId     String?
  proposalManagerId  String?
  executiveSponsorId String?

  nextAction      String?
  nextActionDueAt DateTime?
  lastActivityAt  DateTime?

  // Concurrency + lifecycle
  version    Int       @default(0)
  archivedAt DateTime?
  isDemo     Boolean   @default(false)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  createdBy  String?
  updatedBy  String?

  stageHistory   GovConOpportunityStageHistory[]
  milestones     GovConMilestone[]
  tasks          GovConTask[]
  capturePlan    GovConCapturePlan?
  bidDecision    GovConBidDecision?
  proposals      GovConProposal[]
  requirements   GovConRequirement[]
  reviews        GovConReview[]
  comments       GovConComment[]
  documents      GovConDocument[]
  risks          GovConRisk[]
  partners       GovConOpportunityPartner[]
  interactions   GovConInteraction[]
  submission     GovConSubmission?
  outcome        GovConOutcome?
  activityEvents GovConActivityEvent[]
  tags           GovConTagOnOpportunity[]
  sbirTopic      GovConSbirTopic?

  @@index([hubOrganizationId])
  @@index([hubOrganizationId, stage])
  @@index([hubOrganizationId, health])
  @@index([hubOrganizationId, agencyId])
  @@index([hubOrganizationId, proposalDeadline])
  @@index([hubOrganizationId, archivedAt])
}

model GovConOpportunityStageHistory {
  id                String            @id @default(cuid())
  hubOrganizationId String
  opportunityId     String
  opportunity       GovConOpportunity @relation(fields: [opportunityId], references: [id], onDelete: Cascade)
  fromStage         GovConStage?
  toStage           GovConStage
  changedBy         String? // hubUserId
  note              String?
  createdAt         DateTime          @default(now())

  @@index([hubOrganizationId])
  @@index([opportunityId])
}

model GovConMilestone {
  id                String                @id @default(cuid())
  hubOrganizationId String
  opportunityId     String
  opportunity       GovConOpportunity     @relation(fields: [opportunityId], references: [id], onDelete: Cascade)
  type              GovConMilestoneType   @default(OTHER)
  title             String
  dueAt             DateTime?
  completedAt       DateTime?
  status            GovConMilestoneStatus @default(PENDING)
  ownerId           String? // hubUserId
  notes             String?
  isDemo            Boolean               @default(false)
  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt
  createdBy         String?
  updatedBy         String?

  @@index([hubOrganizationId])
  @@index([opportunityId])
  @@index([hubOrganizationId, dueAt])
  @@index([hubOrganizationId, status])
}

model GovConOpportunityPartner {
  id                String                       @id @default(cuid())
  hubOrganizationId String
  opportunityId     String
  opportunity       GovConOpportunity            @relation(fields: [opportunityId], references: [id], onDelete: Cascade)
  partnerId         String
  partner           GovConPartner                @relation(fields: [partnerId], references: [id], onDelete: Cascade)
  role              GovConTeamRole               @default(SUBCONTRACTOR)
  workshare         Int? // percent 0-100
  scope             String?
  ndaStatus         GovConPartnerAgreementStatus @default(NONE)
  teamingStatus     GovConPartnerAgreementStatus @default(NONE)
  notes             String?
  createdAt         DateTime                     @default(now())
  updatedAt         DateTime                     @updatedAt

  @@unique([opportunityId, partnerId])
  @@index([hubOrganizationId])
  @@index([partnerId])
}

// ---------------------------------------------------------------------------
// Capture planning
// ---------------------------------------------------------------------------

model GovConCapturePlan {
  id                       String            @id @default(cuid())
  hubOrganizationId        String
  opportunityId            String            @unique
  opportunity              GovConOpportunity @relation(fields: [opportunityId], references: [id], onDelete: Cascade)
  ownerId                  String? // hubUserId
  customerMission          String?
  customerProblem          String?
  acquisitionContext       String?
  procurementHistory       String?
  incumbentAnalysis        String?
  competitiveLandscape     String?
  stakeholderMap           String?
  relationshipMap          String?
  decisionRoles            String?
  strengths                String?
  weaknesses               String?
  competitorStrengths      String?
  competitorWeaknesses     String?
  discriminators           String?
  winThemes                String?
  ghostThemes              String?
  proofPoints              String?
  pastPerformanceAlignment String?
  teamingGaps              String?
  staffingGaps             String?
  technicalGaps            String?
  readinessGaps            String?
  pricingPosture           String?
  captureActions           String?
  version                  Int               @default(0)
  createdAt                DateTime          @default(now())
  updatedAt                DateTime          @updatedAt
  createdBy                String?
  updatedBy                String?

  sections GovConCaptureSection[]

  @@index([hubOrganizationId])
}

model GovConCaptureSection {
  id                String                     @id @default(cuid())
  hubOrganizationId String
  capturePlanId     String
  capturePlan       GovConCapturePlan          @relation(fields: [capturePlanId], references: [id], onDelete: Cascade)
  title             String
  body              String?
  ownerId           String? // hubUserId
  status            GovConCaptureSectionStatus @default(DRAFT)
  orderIndex        Int                        @default(0)
  approvedBy        String?
  approvedAt        DateTime?
  lockedAt          DateTime?
  version           Int                        @default(0)
  createdAt         DateTime                   @default(now())
  updatedAt         DateTime                   @updatedAt

  @@index([hubOrganizationId])
  @@index([capturePlanId])
}

// ---------------------------------------------------------------------------
// Bid / no-bid decision
// ---------------------------------------------------------------------------

model GovConBidDecision {
  id                String            @id @default(cuid())
  hubOrganizationId String
  opportunityId     String            @unique
  opportunity       GovConOpportunity @relation(fields: [opportunityId], references: [id], onDelete: Cascade)
  outcome           GovConBidOutcome  @default(PENDING)
  weightedScore     Decimal?          @db.Decimal(6, 2)
  maxScore          Decimal?          @db.Decimal(6, 2)
  criteriaJson      Json? // per-criterion score + weight snapshot
  rationale         String?
  decidedBy         String? // hubUserId who recorded the final decision
  decidedAt         DateTime?
  requiredApprovers String[] // hubUserIds
  version           Int               @default(0)
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  createdBy         String?
  updatedBy         String?

  reviews GovConBidDecisionReview[]

  @@index([hubOrganizationId])
}

model GovConBidDecisionReview {
  id                String            @id @default(cuid())
  hubOrganizationId String
  bidDecisionId     String
  bidDecision       GovConBidDecision @relation(fields: [bidDecisionId], references: [id], onDelete: Cascade)
  reviewerId        String // hubUserId
  vote              GovConBidOutcome  @default(PENDING)
  score             Decimal?          @db.Decimal(6, 2)
  comments          String?
  approved          Boolean?
  reviewedAt        DateTime?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  @@unique([bidDecisionId, reviewerId])
  @@index([hubOrganizationId])
}

// ---------------------------------------------------------------------------
// Proposal room
// ---------------------------------------------------------------------------

model GovConProposal {
  id                String             @id @default(cuid())
  hubOrganizationId String
  opportunityId     String
  opportunity       GovConOpportunity  @relation(fields: [opportunityId], references: [id], onDelete: Cascade)
  title             String
  managerId         String? // hubUserId
  dueAt             DateTime?
  status            GovConVolumeStatus @default(NOT_STARTED)
  notes             String?
  version           Int                @default(0)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  createdBy         String?
  updatedBy         String?

  volumes      GovConProposalVolume[]
  requirements GovConRequirement[]
  reviews      GovConReview[]
  tasks        GovConTask[]

  @@index([hubOrganizationId])
  @@index([opportunityId])
}

model GovConProposalVolume {
  id                String             @id @default(cuid())
  hubOrganizationId String
  proposalId        String
  proposal          GovConProposal     @relation(fields: [proposalId], references: [id], onDelete: Cascade)
  name              String
  ownerId           String? // hubUserId
  reviewerId        String? // hubUserId
  contributors      String[] // hubUserIds
  status            GovConVolumeStatus @default(NOT_STARTED)
  dueAt             DateTime?
  pageLimit         Int?
  currentPages      Int?
  outline           String?
  sourceMaterial    String?
  draftLocation     String?
  orderIndex        Int                @default(0)
  version           Int                @default(0)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  requirements GovConRequirement[]

  @@index([hubOrganizationId])
  @@index([proposalId])
}

model GovConRequirement {
  id                String                  @id @default(cuid())
  hubOrganizationId String
  opportunityId     String
  opportunity       GovConOpportunity       @relation(fields: [opportunityId], references: [id], onDelete: Cascade)
  proposalId        String?
  proposal          GovConProposal?         @relation(fields: [proposalId], references: [id], onDelete: SetNull)
  volumeId          String?
  volume            GovConProposalVolume?   @relation(fields: [volumeId], references: [id], onDelete: SetNull)
  refId             String // requirement id, e.g. L.3.2 / M.1
  sourceSection     String?
  text              String
  requirementType   GovConRequirementType   @default(SHALL)
  mandatory         Boolean                 @default(true)
  responseSection   String?
  ownerId           String? // hubUserId
  status            GovConRequirementStatus @default(UNASSIGNED)
  evidence          String?
  reviewerId        String?
  notes             String?
  createdAt         DateTime                @default(now())
  updatedAt         DateTime                @updatedAt
  createdBy         String?
  updatedBy         String?

  @@index([hubOrganizationId])
  @@index([opportunityId])
  @@index([proposalId])
  @@index([hubOrganizationId, status])
}

model GovConReview {
