{
  "name": "@mactech-solutions-llc/design-tokens",
  "version": "0.1.1",
  "description": "Design tokens for the MacTech Suite — moods, Tailwind preset, motion, fonts.",
  "license": "UNLICENSED",
  "repository": {
    "type": "git",
    "url": "https://github.com/WELCOMETOTHETRIBE/mactech-design.git",
    "directory": "packages/design-tokens"
  },
  "homepage": "https://github.com/WELCOMETOTHETRIBE/mactech-design",
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "restricted"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./fonts": {
      "types": "./dist/fonts.d.mts",
      "default": "./src/fonts.ts"
    },
    "./moods/vivid.css": "./dist/moods/vivid.css",
    "./moods/quiet.css": "./dist/moods/quiet.css",
    "./moods/editorial.css": "./dist/moods/editorial.css",
    "./moods/brutalist.css": "./dist/moods/brutalist.css"
  },
  "files": ["dist", "src/fonts.ts"],
  "peerDependencies": {
    "next": ">=14",
    "react": ">=18",
    "tailwindcss": "^3"
  },
  "peerDependenciesMeta": {
    "next": { "optional": true },
    "react": { "optional": true }
  },
  "scripts": {
    "build": "tsup && npm run copy:moods",
    "copy:moods": "mkdir -p dist/moods && cp src/moods/*.css dist/moods/",
    "dev": "tsup --watch"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "next": "^15.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwindcss": "^3.4.0",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0"
  }
}
