# Clerk — Authentication
# NEXT_PUBLIC_* vars are inlined into the client bundle by Next.js (browser-safe).
# CLERK_SECRET_KEY is server-side only — NEVER prefix with NEXT_PUBLIC_.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_..."
CLERK_SECRET_KEY="sk_test_..."

# App — canonical URL (production custom hostname; set in Railway for hosted envs)
NEXT_PUBLIC_APP_URL="https://bizops.mactechsolutionsllc.com"
# Local dev:
# NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Clerk — Routes & Redirects (Opportunities pattern)
NEXT_PUBLIC_CLERK_SIGN_IN_URL="/sign-in"
NEXT_PUBLIC_CLERK_SIGN_UP_URL="/sign-up"
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL="/"
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL="/"

# Hub authority (see docs/RAILWAY.md)
HUB_AUTHORITY_MODE="mock"
# Production (Railway): HUB_AUTHORITY_MODE="live"
MACTECH_HUB_URL="https://www.suite.mactechsolutionsllc.com"
# Hub key with the profile_write scope ONLY (ADR-0003). Deliberately separate
# from MACTECH_HUB_SERVICE_TOKEN below: that one carries app_authority_resolve
# and audit_ingest, so overwriting it with a profile-only key breaks login.
MACTECH_HUB_PROFILE_TOKEN=

MACTECH_HUB_SERVICE_TOKEN=""
MACTECH_APP_KEY="bizops"
NODE_ENV="development"

# Database — Prisma (Postgres). Provisioned per-environment in Railway; local dev uses docker.
DATABASE_URL="postgresql://postgres:dev@localhost:5432/bizops_dev"
